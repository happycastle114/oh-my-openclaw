{
  "id": "oh-my-openclaw",
  "enabledByDefault": true,
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "max_ralph_iterations": {
        "type": "number",
        "description": "Maximum number of Ralph loop iterations",
        "default": 10,
        "minimum": 0,
        "maximum": 100
      },
      "todo_enforcer_enabled": {
        "type": "boolean",
        "description": "Enable todo enforcer hook",
        "default": false
      },
      "todo_enforcer_cooldown_ms": {
        "type": "number",
        "description": "Cooldown period between todo enforcer checks (milliseconds)",
        "default": 2000,
        "minimum": 0
      },
      "todo_enforcer_max_failures": {
        "type": "number",
        "description": "Maximum number of failures before disabling todo enforcer",
        "default": 5,
        "minimum": 0
      },
      "comment_checker_enabled": {
        "type": "boolean",
        "description": "Enable comment checker hook",
        "default": true
      },
      "checkpoint_dir": {
        "type": "string",
        "description": "Directory for storing checkpoints",
        "default": "./checkpoints"
      },
      "webhook_bridge_enabled": {
        "type": "boolean",
        "description": "Enable webhook bridge for external notifications",
        "default": false
      },
      "gateway_url": {
        "type": "string",
        "description": "OpenClaw Gateway URL",
        "default": "http://127.0.0.1:18789"
      },
      "hooks_token": {
        "type": "string",
        "description": "Authentication token for hooks",
        "default": "",
        "sensitive": true
      },
      "webhook_reminder_interval_ms": {
        "type": "number",
        "description": "Interval for webhook reminders (milliseconds)",
        "default": 300000,
        "minimum": 0
      },
      "webhook_subagent_stale_threshold_ms": {
        "type": "number",
        "description": "Threshold for considering subagent stale (milliseconds)",
        "default": 600000,
        "minimum": 0
      }
    }
  }
}
